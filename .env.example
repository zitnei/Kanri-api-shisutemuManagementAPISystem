# ============================================
# KANRI API SYSTEM - 環境変数設定例
# cp .env.example .env して値を設定してください
# ============================================

# --- Database ---
DATABASE_URL="postgresql://kanri:kanri_secret@localhost:5432/kanri_db"

# --- Redis ---
REDIS_URL="redis://localhost:6379"

# --- JWT ---
JWT_SECRET="change-this-to-a-secure-random-string-minimum-32-chars"
JWT_REFRESH_SECRET="change-this-refresh-secret-also-minimum-32-chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# --- Server ---
PORT=3001
NODE_ENV="development"
CORS_ORIGIN="http://localhost:3000"
